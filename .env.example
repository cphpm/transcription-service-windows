# Gemini API Configuration
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Ollama Configuration (using your local Ollama installation)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Gemma Model Name (the existing model you have)
GEMMA_MODEL_NAME=gemma3:12b

# HuggingFace token for pyannote.audio "Maximum Fidelity" speaker diarization (optional)
# Get token from: https://huggingface.co/settings/tokens
# Accept model terms at: https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=
